    "The %@ hook will be removed from the list. Nothing is written to disk until you save, and Discard still undoes this.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 훅이 목록에서 제거됩니다. 저장하기 전까지 디스크에는 아무것도 기록되지 않으며, 되돌리기로 취소할 수 있어요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El hook %@ se eliminará de la lista. No se escribe nada en el disco hasta que guardes, y Descartar aún puede deshacer esto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 钩子将从列表中移除。在你保存之前不会写入磁盘,且“放弃更改”仍可撤销此操作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ フックがリストから削除されます。保存するまでディスクには何も書き込まれず、「破棄」でこの操作を取り消せます。"
          }
        }
      }
    },
    "“%@” will be removed from the list. Nothing is written to disk until you save, and Discard still undoes this.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”이(가) 목록에서 제거됩니다. 저장하기 전까지 디스크에는 아무것도 기록되지 않으며, 되돌리기로 취소할 수 있어요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” se eliminará de la lista. No se escribe nada en el disco hasta que guardes, y Descartar aún puede deshacer esto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”将从列表中移除。在你保存之前不会写入磁盘,且“放弃更改”仍可撤销此操作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」がリストから削除されます。保存するまでディスクには何も書き込まれず、「破棄」でこの操作を取り消せます。"
          }
        }
